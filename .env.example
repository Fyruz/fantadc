# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://fantadc:fantadc@localhost:5432/fantadc"

# ─── Auth.js v5 ────────────────────────────────────────────────────────────────
# Generare con: openssl rand -base64 32
AUTH_SECRET="generate-with: openssl rand -base64 32"

# Durata sessione in secondi (default: 30 giorni = 2592000)
AUTH_SESSION_MAX_AGE=2592000

# ─── Seed ──────────────────────────────────────────────────────────────────────
# Email e password dell'admin creato alla prima esecuzione di `npm run db:seed`
# IMPORTANTE: cambiare questi valori prima del go-live e aggiornare la password
# dell'admin via pannello admin dopo il primo accesso.
SEED_ADMIN_EMAIL="admin@fantadc.local"
SEED_ADMIN_PASSWORD="changeme"

# ─── Ambiente (opzionale) ───────────────────────────────────────────────────────
# NODE_ENV="production"

# URL pubblica dell'applicazione.
# Serve per metadata assoluti, manifest PWA, deep link nelle notifiche e packaging store.
NEXTAUTH_URL="https://fantadc.example.com"
# In alternativa puoi esporre la stessa URL anche lato client se necessario.
# NEXT_PUBLIC_APP_URL="https://fantadc.example.com"

# ─── Push notifications Web Push / VAPID ──────────────────────────────────────
# Genera una coppia una sola volta con:
# npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Deve essere una mailto: o una URL https:
VAPID_SUBJECT="mailto:admin@fantadc.example.com"
