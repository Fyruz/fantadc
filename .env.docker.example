# Variabili non-sensibili — da copiare in .env.docker
# Queste vengono caricate via env_file nel container dell'app

# URL pubblica dell'app (no trailing slash) — usato da NextAuth
NEXTAUTH_URL=https://fantadc.example.com

# ---------------------------------------------------------------------------
# Variabili SENSIBILI — in produzione vengono iniettate da Jenkins
# via withCredentials e NON vanno in .env.docker
#
# Per uso LOCALE crea un file .env nella root del progetto con:
#
# POSTGRES_USER=fantadc_user
# POSTGRES_PASSWORD=changeme
# POSTGRES_DB=fantadc
# NEXTAUTH_SECRET=your-super-secret-key
#
# Docker Compose legge automaticamente .env per l'interpolazione
# dei ${VAR} nel file docker-compose.prod.yml
# ---------------------------------------------------------------------------
