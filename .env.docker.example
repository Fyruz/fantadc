# Variabili non-sensibili per l'ambiente PROD — da copiare in .env.docker
# Caricate via env_file nel container (docker-compose.prod.yml)
#
# L'ambiente DEV non usa .env.docker: tutte le variabili vengono
# iniettate direttamente dal Jenkinsfile o da docker-compose.yml.

# URL pubblica dell'app in prod (no trailing slash) — usato da NextAuth
NEXTAUTH_URL=https://dcup.nuovapolisportivachianti.it

# Seed admin PROD (eseguito sempre dal Jenkinsfile_prod).
# Se la password non è impostata, il deploy fallisce.
PROD_ADMIN_EMAIL=admin@nuovapolisportivachianti.it
# ATTENZIONE: se la password inizia con "#" racchiudila tra virgolette.
# Esempio: PROD_ADMIN_PASSWORD="#Ellidhn1"
# PROD_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Variabili SENSIBILI — in produzione vengono iniettate da Jenkins
# via withCredentials e NON vanno in .env.docker:
#
#   fantadc-db-prod        → POSTGRES_USER / POSTGRES_PASSWORD
#   fantadc-nextauth-secret-prod → NEXTAUTH_SECRET
#
# Per uso LOCALE crea un file .env nella root del progetto con:
#
# POSTGRES_USER=fantadc_user
# POSTGRES_PASSWORD=changeme
# POSTGRES_DB=fantadc
# NEXTAUTH_SECRET=your-super-secret-key
# ---------------------------------------------------------------------------
